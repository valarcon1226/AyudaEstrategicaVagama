# Normalizar line endings en Git
* text=auto

# Archivos que siempre deben usar LF (Unix)
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
*.json text eol=lf
*.md text eol=lf

# Archivos binarios
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
